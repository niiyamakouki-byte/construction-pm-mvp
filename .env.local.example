# GenbaHub — ローカル環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# cp .env.local.example .env.local
#
# .env.local は Git 管理外（.gitignore で除外済み）。実値を直接書いて OK。

# ── サーバーサイド ─────────────────────────────────────────────
USE_SUPABASE=true
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
API_KEY=replace-with-a-long-random-api-key

# ── フロントエンド (Vite) ──────────────────────────────────────
# VITE_USE_SUPABASE=true にすると Repository が Supabase 実装に切り替わる
VITE_USE_SUPABASE=true
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe（オプション） ───────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_STRIPE_PRICE_STANDARD=price_standard_id_here
VITE_STRIPE_PRICE_PRO=price_pro_id_here

# ── Discord 中継チャット（オプション） ────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHAT_CHANNEL_ID=1489407813230002347

# ── freee 連携（オプション） ──────────────────────────
# AES-GCM 暗号化キー (256-bit, base64 エンコード)
# 生成例: openssl rand -base64 32
VITE_FREEE_ENCRYPTION_KEY=your-base64-256bit-key-here
