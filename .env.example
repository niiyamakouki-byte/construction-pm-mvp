USE_SUPABASE=false
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
API_KEY=replace-with-a-long-random-api-key

# Client-side Vite variables
# Phase B: VITE_USE_SUPABASE=true で Repository が Supabase 実装に切り替わる
# false（既定）の場合は従来通り InMemory 実装を使用
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Stripe (test mode: pk_test_xxx, live: pk_live_xxx)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_STRIPE_PRICE_STANDARD=price_standard_id_here
VITE_STRIPE_PRICE_PRO=price_pro_id_here

# ラポルタ秘書チャット（Discord 中継）
# GenbaHub UI から Discord チャンネルへメッセージを中継する
# DISCORD_BOT_TOKEN: Discord Developer Portal の Bot Token（Git に commit しないこと）
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHAT_CHANNEL_ID=1489407813230002347
