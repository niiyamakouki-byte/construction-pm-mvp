USE_SUPABASE=false
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
API_KEY=replace-with-a-long-random-api-key

# Client-side Vite variables
# Sprint 61 Phase 1: FEATURE_SUPABASE = VITE_USE_SUPABASE のエイリアス
# true にすると全 Repository が Supabase 実装に切り替わる
# false（既定）の場合は従来通り InMemory 実装を使用（既存動作維持）
# 光輝さんが Supabase Cloud の鍵を投入後に true へ変更する
FEATURE_SUPABASE=false
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Stripe
# STRIPE_SECRET_KEY: 開発=sk_test_xxx / 本番=sk_live_xxx (NODE_ENV=production で prefix チェックあり)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STANDARD=price_standard_id_here
STRIPE_PRICE_PRO=price_pro_id_here
# APP_BASE_URL: CORS 許可オリジン (未設定時は https://construction-pm-mvp.vercel.app)
APP_BASE_URL=https://construction-pm-mvp.vercel.app
# Client-side Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_STRIPE_PRICE_STANDARD=price_standard_id_here
VITE_STRIPE_PRICE_PRO=price_pro_id_here

# ラポルタ秘書チャット（Discord 中継）
# GenbaHub UI から Discord チャンネルへメッセージを中継する
# DISCORD_BOT_TOKEN: Discord Developer Portal の Bot Token（Git に commit しないこと）
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHAT_CHANNEL_ID=1489407813230002347

# freee 会計連携 (Sprint 62)
# freee Developer Console で取得: https://app.secure.freee.co.jp/developers
# VITE_ プレフィックスはブラウザ側で参照される
VITE_FREEE_CLIENT_ID=your-freee-client-id
VITE_FREEE_REDIRECT_URI=http://localhost:5173/freee/callback
# サーバー側 (Vercel Function) で使用するシークレット — Git に commit しないこと
FREEE_CLIENT_SECRET=your-freee-client-secret
FREEE_ACCESS_TOKEN=
